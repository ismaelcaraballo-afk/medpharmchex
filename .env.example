# ── MedRxChex Backend Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your secret API key.

# Required: Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Enable demo mode — returns pre-set results for warfarin/ibuprofen/lisinopril
# without making live API calls. Safe for demos/testing.
# DEMO_MODE=true

# Production only: URL of your deployed frontend (e.g. https://medrxchex.vercel.app)
# FRONTEND_URL=https://your-app.vercel.app

# Server port (default: 3001)
# PORT=3001
