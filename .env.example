ANTHROPIC_API_KEY=your_anthropic_key_here

# URL of the deployed frontend (used to restrict CORS in production)
# WHY: Allowing all origins (*) lets any website call our API — a security risk.
# Set this to your Vercel frontend URL once deployed.
FRONTEND_URL=https://medchex.vercel.app

# Node environment — set to "production" on Vercel automatically
NODE_ENV=development

# Demo Day safety net — set to "true" on Vercel before March 18
# WHY: Live API calls during a presentation are a single point of failure.
# DEMO_MODE returns pre-validated cached data for Warfarin/Ibuprofen/Aspirin/Lisinopril
# so the demo runs perfectly even if OpenFDA or RxNorm are slow or down.
DEMO_MODE=false

# Frontend env var — set in Vercel dashboard under project settings
# WHY: The React frontend needs to know where the backend lives.
# In development this defaults to localhost:3001 automatically.
VITE_API_URL=https://medchex.vercel.app/api
